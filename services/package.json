{
  "name": "shepherd",
  "version": "0.1.1",
  "description": "Server that creates & maintains a strict adult content filter list.",
  "type": "module",
  "scripts": {
    "migrate": "NODE_OPTIONS='--loader ts-node/esm' knex migrate:latest",
    "typecheck": "tsc --noEmit",
    "test": "jest **/*.spec.ts",
    "test:grep": "jest --verbose --testNamePattern",
    "test-mocha:grep": "NODE_ENV=test mocha tests/**/*.spec.ts --grep",
    "test-mocha": "NODE_ENV=test mocha tests/**/*.spec.ts"
  },
  "mocha": {
    "extension": [
      "ts"
    ],
    "node-option": [
      "loader=ts-node/esm",
      "loader=esmock",
      "experimental-specifier-resolution=node",
      "no-warnings"
    ]
  },
  "keywords": [],
  "author": "Ros McMahon <ros@arweave.org>",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shepherd-media-classifier/shepherd.git"
  },
  "devDependencies": {
    "@types/jest": "^29.5.6",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "eslint": "^8.48.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.433.0",
    "@aws-sdk/client-secrets-manager": "^3.405.0",
    "@aws-sdk/client-sqs": "^3.433.0",
    "@aws-sdk/lib-storage": "^3.433.0",
    "@slack/webhook": "^6.0.0",
    "@swc/register": "^0.1.10",
    "@types/express": "^4.17.11",
    "@types/node": "^18.11.17",
    "@types/rimraf": "^3.0.1",
    "ansi-colors": "^4.1.1",
    "ar-gql": "^1.2.1",
    "arweave": "^1.11.6",
    "axios": "^0.24.0",
    "csv-parse": "^5.0.4",
    "express": "^4.17.1",
    "file-type": "^18.5.0",
    "got": "^11.8.5",
    "knex": "^2.1.0",
    "knex-utils": "^6.0.0",
    "moize": "^6.1.5",
    "pg": "^8.6.0",
    "pg-query-stream": "^4.2.3",
    "rimraf": "^3.0.2",
    "systeminformation": "^5.9.15",
    "ts-node": "^10.4.0",
    "typescript": "^5.1.3"
  }
}
